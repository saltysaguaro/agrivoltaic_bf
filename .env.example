# Copy the values you need into your shell or a local `.env` file.
# Never commit real credentials or local machine paths.

MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
NSRDB_API_KEY=your_nrel_api_key_here
NSRDB_EMAIL=your_email@example.com

# Optional local runtime configuration
AGRIVOLTAIC_PYTHON=/opt/anaconda3/envs/irradiance/bin/python
AGRIVOLTAIC_RADIANCE_BIN_DIR=$HOME/opt/Radiance/bin
